# Groq-compatible LLM provider.
GROQ_API_KEY=replace-with-groq-api-key

# Tavily is used for web search.
TAVILY_API_KEY=replace-with-tavily-api-key

# Optional Jina AI key for higher page-fetching limits.
# JINA_API_KEY=replace-with-jina-api-key

# Scout Coordinator: Resend inbound email.
RESEND_CREDENTIALS={"api_key":"replace-with-resend-api-key","webhook_secret":"replace-with-resend-webhook-secret","from_email":"Offer Scout <scout@your-domain>"}
# Optional split local fallback.
# RESEND_API_KEY=replace-with-resend-api-key
# RESEND_WEBHOOK_SECRET=replace-with-resend-webhook-secret
# RESEND_FROM_EMAIL="Offer Scout <scout@your-domain>"
RESEND_BASE_URL=https://api.resend.com
RESEND_TIMEOUT_SECONDS=30

# Scout Coordinator: local agent and candidate profile.
SCOUT_AGENT_BASE_URL=http://localhost:8080
SCOUT_AGENT_TIMEOUT_SECONDS=120
# Use cloud_run_oidc when scout-agent is deployed as a private Cloud Run service.
SCOUT_AGENT_AUTH_MODE=none
# Optional. Defaults to SCOUT_AGENT_BASE_URL.
# SCOUT_AGENT_AUDIENCE=https://scout-agent-xxxxx-ew.a.run.app
PROFILE_CONTEXT=Senior Software Engineer looking for remote work.
TASK_BACKEND=local
LOCAL_TASK_RETRY_ATTEMPTS=3

# Used when TASK_BACKEND=cloud_tasks.
CLOUD_TASKS_PROJECT=your-gcp-project
CLOUD_TASKS_LOCATION=europe-west1
CLOUD_TASKS_QUEUE=scout-email-processing
# Optional in Cloud Run. If empty, coordinator derives it from the incoming webhook URL.
# CLOUD_TASKS_TARGET_URL=https://scout-coordinator-xxxxx-ew.a.run.app/tasks/process-email
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=scout-tasks@your-gcp-project.iam.gserviceaccount.com
# Optional. Defaults to CLOUD_TASKS_TARGET_URL or the derived task endpoint URL.
# CLOUD_TASKS_OIDC_AUDIENCE=https://scout-coordinator-xxxxx-ew.a.run.app/tasks/process-email
CLOUD_TASKS_DISPATCH_DEADLINE_SECONDS=600

MAX_ATTACHMENT_BYTES=5242880
MAX_OFFER_TEXT_CHARS=50000
